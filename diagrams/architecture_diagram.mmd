%% YUTrade — High-Level Architecture Diagram
%% Generated 2026-03-31

graph TB
    subgraph Client ["🖥️ Client (Browser)"]
        direction TB
        Browser["React 19 SPA<br/>TypeScript"]
    end

    subgraph Frontend ["Frontend (Vercel)"]
        direction TB

        subgraph Routing ["App Router"]
            AppRouter["React Router v6<br/>13 Routes"]
        end

        subgraph Pages ["Pages (13)"]
            direction LR
            AuthPages["Auth Pages<br/>Login · Register<br/>Forgot/Reset Password"]
            MarketPages["Marketplace Pages<br/>Browse · Create · Edit<br/>Detail · My Listings"]
            CommPages["Communication Pages<br/>Messages · Seller Profile"]
            UtilPages["Utility Pages<br/>Account · Maps"]
        end

        subgraph SharedComponents ["Shared Components"]
            direction LR
            Navbar["Navbar"]
            Layout["Layout"]
            ProtectedRoute["ProtectedRoute"]
            ListingCard["ListingCard"]
            SearchBar["SearchBar"]
            ImageUpload["ImageUpload"]
            StarRating["StarRating"]
            MessageThread["MessageThread"]
        end

        subgraph State ["State Management"]
            direction LR
            AuthContext["AuthContext<br/>(user, token, login, logout)"]
            LocalStorage["localStorage<br/>(JWT persistence)"]
        end

        subgraph APILayer ["API Client Layer"]
            direction LR
            AxiosClient["Axios Instance<br/>JWT Interceptor<br/>401 Auto-redirect"]
            AuthAPI["auth.ts"]
            ListingsAPI["listings.ts"]
            MessagesAPI["messages.ts"]
            RatingsAPI["ratings.ts"]
        end

        subgraph Utils ["Utilities"]
            Validators["validators.ts<br/>Email · Password · Price<br/>Format helpers"]
        end
    end

    subgraph Backend ["Backend (Render)"]
        direction TB

        subgraph ASGI ["FastAPI Application"]
            direction LR
            CORSMiddleware["CORS<br/>Middleware"]
            StaticFiles["/uploads<br/>Static Mount"]
        end

        subgraph Routers ["Routers (HTTP Layer)"]
            direction LR
            AuthRouter["/auth<br/>register · login<br/>forgot/reset-password<br/>me · change-password<br/>delete-account"]
            ListingsRouter["/listings<br/>CRUD + search<br/>pagination + filters"]
            MessagesRouter["/listings/:id/messages<br/>send · get · mark-read"]
            ThreadsRouter["/messages/threads<br/>conversation list"]
            RatingsRouter["/ratings<br/>CRUD per listing<br/>seller aggregates"]
        end

        subgraph Services ["Services (Business Logic)"]
            direction LR
            AuthService["AuthService<br/>register · login<br/>password reset<br/>profile · delete"]
            ListingService["ListingService<br/>create · search<br/>update · delete<br/>image management"]
            MessageService["MessageService<br/>send · fetch<br/>mark read · threads"]
            RatingService["RatingService<br/>create · update<br/>delete · aggregate"]
            EmailService["EmailService<br/>SMTP · Console<br/>Resend backends"]
        end

        subgraph Models ["ORM Models (SQLAlchemy)"]
            direction LR
            UserModel["User"]
            ListingModel["Listing"]
            ImageModel["Image"]
            MessageModel["Message"]
            RatingModel["Rating"]
            VerifModel["VerificationCode"]
            PwResetModel["PasswordResetCode"]
        end

        subgraph Schemas ["Pydantic Schemas"]
            direction LR
            AuthSchemas["Auth Schemas<br/>Register · Login<br/>Token · Reset"]
            ListingSchemas["Listing Schemas<br/>Create · Update<br/>Out · Paginated"]
            MessageSchemas["Message Schemas<br/>Create · Out"]
            RatingSchemas["Rating Schemas<br/>Create · Update<br/>Out · Aggregates"]
            UserSchemas["User Schemas<br/>Profile · Password<br/>Delete"]
        end

        subgraph Infrastructure ["Infrastructure"]
            direction LR
            Config["Config<br/>(pydantic-settings)"]
            Security["Security<br/>bcrypt · JWT<br/>(python-jose)"]
            Dependencies["Dependencies<br/>get_db()<br/>get_current_user()"]
            Database["Database<br/>Engine · Session<br/>FK enforcement"]
        end
    end

    subgraph DataStore ["Data Store"]
        SQLite[("SQLite<br/>yutrade.db")]
        Uploads["📁 uploads/<br/>UUID image files"]
    end

    subgraph ExternalServices ["External Services"]
        direction LR
        SMTP["Gmail SMTP<br/>smtp.gmail.com:587<br/>App Password auth"]
        Resend["Resend API<br/>(optional)"]
    end

    %% Client → Frontend
    Browser --> AppRouter

    %% Frontend internal flow
    AppRouter --> Pages
    Pages --> SharedComponents
    Pages --> State
    Pages --> APILayer
    Pages --> Utils
    SharedComponents --> APILayer
    AuthContext --> LocalStorage
    AxiosClient --> AuthAPI
    AxiosClient --> ListingsAPI
    AxiosClient --> MessagesAPI
    AxiosClient --> RatingsAPI

    %% Frontend → Backend (HTTP/REST)
    APILayer -- "HTTP/REST<br/>JSON + multipart" --> CORSMiddleware

    %% Backend internal flow
    CORSMiddleware --> Routers
    Routers --> Services
    Services --> Models
    Routers --> Schemas
    Services --> Infrastructure
    Infrastructure --> Database

    %% Backend → Data Store
    Database --> SQLite
    ListingService --> Uploads

    %% Backend → External
    EmailService --> SMTP
    EmailService -.-> Resend

    %% Cross-cutting
    Dependencies -- "JWT validation" --> Security
    Dependencies -- "DB session" --> Database
    Config -- "env vars" --> ASGI
    Config -- "env vars" --> Services
    Config -- "env vars" --> Infrastructure

